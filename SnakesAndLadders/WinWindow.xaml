<Window x:Class="SnakesAndLadders.WinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnakesAndLadders"
        mc:Ignorable="d"
        Title="WinWindow" Height="620" Width="750"
        WindowStartupLocation="CenterScreen">
    <Grid Background="Black">
        <StackPanel Margin="152,21,152,19">

            <TextBlock x:Name="WinnerText"
       Text="Player Wins!"
       FontSize="32"
       Foreground="Gold"
       HorizontalAlignment="Center"
       Margin="0 0 0 20"/>
            
            <Image x:Name="VictoryImage"
                   Source="Images/Win/Win.png"
       Stretch="Fill"
               Width="300"
               Margin="0 0 0 20"/>

            

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 20 0 0">
                <Button Content="Play Again" Width="120" Margin="10" Click="PlayAgain_Click"/>
                <Button Content="Exit" Width="120" Margin="10" Click="Exit_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
